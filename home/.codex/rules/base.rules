prefix_rule(
    pattern=["sql-read", "run"],
    decision="allow",
    justification="The persisted-target sql-read run path is read-only by construction.",
    match=[
        "sql-read run --state-dir /Users/anthonyaltieri/.codex/skills/sql-read/state --target prod-readonly --file /tmp/query.sql --format json",
    ],
    not_match=[
        "sql-read target upsert --state-dir /Users/anthonyaltieri/.codex/skills/sql-read/state --name prod-readonly --engine postgres --dsn-env-var PROD_READONLY_URL",
    ],
)

prefix_rule(
    pattern=["fetch-comments"],
    decision="allow",
    justification="fetch-comments only reads PR review data from GitHub.",
    match=[
        "fetch-comments --format compact",
        "fetch-comments --format json",
    ],
    not_match=[
        "create-comment --body FROM CODEX: ready for another look.",
    ],
)

prefix_rule(
    pattern=["summarize-threads"],
    decision="allow",
    justification="summarize-threads only reads local input and emits a summary.",
    match=[
        "summarize-threads /tmp/pr-threads.tsv",
    ],
    not_match=[
        "resolve-thread --thread-id PRRT_example",
    ],
)

prefix_rule(
    pattern=["inspect-pr-checks"],
    decision="allow",
    justification="inspect-pr-checks only inspects PR checks and log excerpts.",
    match=[
        "inspect-pr-checks --repo . --json",
        "inspect-pr-checks --repo . --pr 2667 --json",
    ],
    not_match=[
        "classify-ci-log /tmp/failed.log",
    ],
)

prefix_rule(
    pattern=["classify-ci-log"],
    decision="allow",
    justification="classify-ci-log only reads local CI log input and emits a local summary.",
    match=[
        "classify-ci-log /tmp/failed.log",
    ],
    not_match=[
        "inspect-pr-checks --repo . --json",
    ],
)

prefix_rule(
    pattern=["sql-read", "target"],
    decision="prompt",
    justification="Target mutation stores connection details and should stay approval-gated.",
    match=[
        "sql-read target upsert --state-dir /Users/anthonyaltieri/.codex/skills/sql-read/state --name prod-readonly --engine postgres --dsn-env-var PROD_READONLY_URL",
    ],
    not_match=[
        "sql-read run --state-dir /Users/anthonyaltieri/.codex/skills/sql-read/state --target prod-readonly --file /tmp/query.sql --format json",
    ],
)

prefix_rule(
    pattern=["create-comment"],
    decision="prompt",
    justification="Posting PR comments mutates GitHub state and should keep prompting.",
    match=[
        "create-comment --body FROM CODEX: ready for another look.",
    ],
    not_match=[
        "fetch-comments --format json",
    ],
)

prefix_rule(
    pattern=["create-thread-reply"],
    decision="prompt",
    justification="Replying to review threads mutates GitHub state and should keep prompting.",
    match=[
        "create-thread-reply --thread-id PRRT_example --body FROM CODEX: Addressed in abc123 - fixed the issue.",
    ],
    not_match=[
        "summarize-threads /tmp/pr-threads.tsv",
    ],
)

prefix_rule(
    pattern=["resolve-thread"],
    decision="prompt",
    justification="Resolving review threads mutates GitHub state and should keep prompting.",
    match=[
        "resolve-thread --thread-id PRRT_example",
    ],
    not_match=[
        "fetch-comments --format compact",
    ],
)
