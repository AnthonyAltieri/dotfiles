theme = Catppuccin Macchiato
font-family = "BerkeleyMono"
window-title-font-family = "BerkeleyMono"
font-size = 14
shell-integration = zsh
confirm-close-surface = false
macos-option-as-alt = true
macos-titlebar-style = tabs
window-save-state = always
custom-shader = shaders/cursor_tail.glsl

#keybinds
# Explicitly unbind Ghostty's default split navigation so Ctrl+h/j/k/l reach tmux + Neovim.
keybind = ctrl+h=unbind
keybind = ctrl+j=unbind
keybind = ctrl+k=unbind
keybind = ctrl+l=unbind

# Keep terminal-level split navigation available on a shifted variant.
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+j=goto_split:bottom
keybind = ctrl+shift+k=goto_split:top
keybind = ctrl+shift+l=goto_split:right

keybind = cmd+h=previous_tab
keybind = cmd+l=next_tab

keybind = super+ctrl+h=resize_split:left,10
keybind = super+ctrl+j=resize_split:down,10
keybind = super+ctrl+k=resize_split:up,10
keybind = super+ctrl+l=resize_split:right,10
keybind = shift+enter=text:\x1b\r
keybind = ctrl+.=text:\x1b[46;5u

# Ctrl+N -> tmux prefix (C-Space = \x00) + digit -> select window N
keybind = ctrl+1=text:\x00\x31
keybind = ctrl+2=text:\x00\x32
keybind = ctrl+3=text:\x00\x33
keybind = ctrl+4=text:\x00\x34
keybind = ctrl+5=text:\x00\x35
keybind = ctrl+6=text:\x00\x36
keybind = ctrl+7=text:\x00\x37
keybind = ctrl+8=text:\x00\x38
keybind = ctrl+9=text:\x00\x39
